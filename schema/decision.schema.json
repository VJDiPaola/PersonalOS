{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personalos.dev/schema/decision.schema.json",
  "title": "PersonalOS Decision",
  "description": "Schema for decision entities.",
  "type": "object",
  "allOf": [
    { "$ref": "_base.schema.json" }
  ],
  "properties": {
    "type": { "const": "decision" },
    "status": {
      "type": "string",
      "enum": ["open", "decided", "revisited", "archived"]
    },
    "question": { "type": "string", "minLength": 1 },
    "outcome": { "type": "string" },
    "decided_date": { "$ref": "_base.schema.json#/$defs/iso_date" },
    "related_entity_ids": { "$ref": "_base.schema.json#/$defs/id_list" }
  },
  "required": ["id", "type", "slug", "title", "status", "question", "created_at", "updated_at"]
}
