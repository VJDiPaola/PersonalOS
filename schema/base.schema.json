{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personalos.dev/schema/base.schema.json",
  "title": "PersonalOS base entity",
  "type": "object",
  "required": [
    "id",
    "type",
    "slug",
    "title",
    "status",
    "created_at",
    "updated_at",
    "tags",
    "summary"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z]{3}_[a-z0-9_]+$"
    },
    "type": {
      "type": "string",
      "enum": [
        "project",
        "task",
        "decision"
      ]
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "status": {
      "type": "string",
      "minLength": 2
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2
      },
      "uniqueItems": true
    },
    "summary": {
      "type": "string",
      "minLength": 12
    }
  },
  "additionalProperties": true
}
