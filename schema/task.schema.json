{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personalos.dev/schema/task.schema.json",
  "title": "PersonalOS Task",
  "description": "Schema for task entities.",
  "type": "object",
  "allOf": [
    { "$ref": "_base.schema.json" }
  ],
  "properties": {
    "type": { "const": "task" },
    "status": {
      "type": "string",
      "enum": ["todo", "in_progress", "blocked", "done", "archived"]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "project_id": { "$ref": "_base.schema.json#/$defs/ulid_id" },
    "due_date": { "$ref": "_base.schema.json#/$defs/iso_date" },
    "assignee": { "type": "string" }
  },
  "required": ["id", "type", "slug", "title", "status", "priority", "created_at", "updated_at"]
}
